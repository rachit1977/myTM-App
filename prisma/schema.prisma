generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------------------
//  Auth (NextAuth-compatible) + User profile + preferences
// ----------------------------------------------------------------

enum Tier {
  Silver
  Gold
  Platinum
}

model User {
  id           String   @id @default(cuid())
  fullName     String
  email        String   @unique
  phone        String   @unique
  passwordHash String
  avatarUrl    String?
  memberSince  DateTime @default(now())
  points       Int      @default(0)
  tier         Tier     @default(Silver)

  // Notification + privacy preferences (stored as JSON for flexibility)
  notificationPrefs Json @default("{}")
  privacyPrefs      Json @default("{}")

  reports       Report[]
  luckyEntries  LuckyDrawEntry[]
  notifications Notification[]
  sessions      Session[]
  accounts      Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ----------------------------------------------------------------
//  Catalog
// ----------------------------------------------------------------

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  tagline     String
  description String
  features    String[] @default([])
  usage       String[] @default([])
  warnings    String[] @default([])
  specs       Json     @default("[]")
  price       String?
  sourceUrl   String
  imageUrl    String

  serials ProductSerial[]
  reports Report[]
  entries LuckyDrawEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSerial {
  id             String   @id @default(cuid())
  serial         String   @unique
  productId      String
  isAuthentic    Boolean  @default(true)
  manufacturedAt DateTime
  warrantyUntil  DateTime
  batch          String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ----------------------------------------------------------------
//  Reports (แจ้งปัญหาสินค้า)
// ----------------------------------------------------------------

enum ReportStatus {
  pending
  in_progress
  resolved
}

model Report {
  id        String       @id @default(cuid())
  userId    String
  productId String
  topic     String
  detail    String
  imageUrls String[]     @default([])
  status    ReportStatus @default(pending)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------
//  Lucky Draw entries
// ----------------------------------------------------------------

enum LuckyDrawStatus {
  pending
  approved
  rejected
}

model LuckyDrawEntry {
  id           String          @id @default(cuid())
  userId       String
  productId    String
  fullName     String
  address      String
  receiptNo    String
  amount       Decimal         @db.Decimal(10, 2)
  productImage String
  receiptImage String
  status       LuckyDrawStatus @default(pending)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ----------------------------------------------------------------
//  Winners announcement (public)
// ----------------------------------------------------------------

model Winner {
  id        String   @id @default(cuid())
  rank      Int      @default(1)
  name      String
  prize     String
  drawDate  DateTime
  province  String
  createdAt DateTime @default(now())

  @@index([drawDate, rank])
}

// ----------------------------------------------------------------
//  Notifications (per-user inbox)
// ----------------------------------------------------------------

enum NotificationType {
  lucky_draw
  report
  promotion
  system
  winner
}

model Notification {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  title   String
  message String
  href    String?
  read    Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
